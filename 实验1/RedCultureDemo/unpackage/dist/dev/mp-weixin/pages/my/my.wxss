
.my {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}
.avatar image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid #C00000;
}
.info {
  margin-top: 40rpx;
  text-align: center;
}
.name {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
}
.student-id, .class {
  font-size: 32rpx;
  color: #666;
  display: block;
  margin-top: 12rpx;
}
.quote {
  margin-top: 60rpx;
  font-size: 36rpx;
  font-style: italic;
  color: #C00000;
  padding: 30rpx;
  background-color: #f9f9f9;
  border-radius: 16rpx;
}
