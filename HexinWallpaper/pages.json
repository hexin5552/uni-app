{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@/uni_modules/uni-$1/components/uni-$1/uni-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "HexinWallpaper",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/classify/classify",
			"style": {
				"navigationBarTitleText": "分类",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/user/user",
			"style": {
				"navigationBarTitleText": "我的",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/classlist/classlist",
			"style": {
				"navigationBarTitleText": "分类列表",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/preview/preview",
			"style": {
				"navigationBarTitleText": "预览",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/downloads/downloads",
			"style": {
				"navigationBarTitleText": "我的下载",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/scores/scores",
			"style": {
				"navigationBarTitleText": "我的评分",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/favorites/favorites",
			"style": {
				"navigationBarTitleText": "我的收藏",
				"navigationStyle": "custom"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "HexinWallpaper",
		"navigationBarBackgroundColor": "#fff",
		"backgroundColor": "#F8F8F8"
	},
	"tabBar": {
		"color": "#9799a5",
		"selectedColor": "#28b389",
		"list": [
			{
				"text": "推荐",
				"pagePath": "pages/index/index",
				"iconPath": "/static/pages/tabBar/home.png",
				"selectedIconPath": "/static/pages/tabBar/home-h.png"
			},
			{
				"text": "分类",
				"pagePath": "pages/classify/classify",
				"iconPath": "/static/pages/tabBar/classify.png",
				"selectedIconPath": "/static/pages/tabBar/classify-h.png"
			},
			{
				"text": "我的",
				"pagePath": "pages/user/user",
				"iconPath": "/static/pages/tabBar/user.png",
				"selectedIconPath": "/static/pages/tabBar/user-h.png"
			}
		]
	},
	"uniIdRouter": {}
}
